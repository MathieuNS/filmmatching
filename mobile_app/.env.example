# Modèle de configuration — copie ce fichier en `.env` puis adapte la valeur.
#   cp .env.example .env   (ou copie manuelle sous Windows)
#
# URL de base du backend Django.
# Sur téléphone physique : remplace localhost par l'IP locale de ton PC
# (ex. http://192.168.1.42:8000), trouvable avec `ipconfig`.
EXPO_PUBLIC_API_URL=http://localhost:8000
